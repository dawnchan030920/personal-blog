---
import { type CollectionEntry } from "astro:content";
import HomepageItemCardContainer from "./HomepageItemCardContainer.astro";

type Props = {
  series: CollectionEntry<"series">;
};

const { series } = Astro.props;

const titleData = {
  text: series.data.title,
  link: `/series/${series.slug}`,
};
---

<HomepageItemCardContainer title={titleData} />
